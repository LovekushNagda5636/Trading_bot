# ═══════════════════════════════════════════════════════════════
# Angel One Trading Bot — Environment Variables
# Copy this file to .env and fill in your real credentials
# ═══════════════════════════════════════════════════════════════

# Angel One API Credentials
ANGEL_ONE_API_KEY=your_api_key_here
ANGEL_ONE_API_SECRET=your_api_secret_here
ANGEL_ONE_CLIENT_CODE=your_client_code_here
ANGEL_ONE_PASSWORD=your_password_here
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here
ANGEL_ONE_TOTP_ENABLED=true

# Dashboard Authentication (leave empty for dev mode / open access)
DASHBOARD_TOKEN=

# Trading Mode (set to 'false' to enable live trading — USE WITH CAUTION)
# PAPER_TRADING=true

# Optional: Alert Configuration
# ALERT_EMAIL=your.email@example.com
